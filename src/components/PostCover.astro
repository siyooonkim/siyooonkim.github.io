---
import type { CollectionEntry } from 'astro:content';

type PostData = CollectionEntry<'blog'>['data'];

interface Props {
	post?: CollectionEntry<'blog'>;
	data?: PostData;
	compact?: boolean;
}

const { post, data, compact = false } = Astro.props;
const source = post?.data ?? data;

if (!source) {
	throw new Error('PostCover requires either post or data.');
}

const titleWords = source.title.split(' ').slice(0, 8).join(' ');
const publishedYear = source.pubDate instanceof Date ? source.pubDate.getFullYear() : new Date(source.pubDate).getFullYear();
---

{
	source.heroImage ? (
		<img
			class:list={["cover-image", { compact }]}
			src={source.heroImage}
			alt={source.title}
		/>
	) : (
		<div class:list={["generated-cover", { compact }]}>
			<div class="cover-content">
				<span class="cover-category">{source.category}</span>
				<h4 class="cover-title">{titleWords}</h4>
				<span class="cover-year">{publishedYear}</span>
			</div>
		</div>
	)
}

<style>
	.cover-image {
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: 0;
	}
	.cover-image.compact {
		aspect-ratio: 3 / 4;
	}

	.generated-cover {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: linear-gradient(145deg, #1a1f28 0%, #141921 100%);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.generated-cover.compact {
		aspect-ratio: 3 / 4;
	}

	.cover-content {
		width: 100%;
		height: 100%;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.cover-category {
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.cover-title {
		margin: 0;
		font-size: clamp(1rem, 0.9rem + 0.4vw, 1.25rem);
		font-weight: 700;
		line-height: 1.35;
		color: var(--text-strong);
		letter-spacing: -0.01em;
	}

	.cover-year {
		font-size: 0.72rem;
		color: var(--text-subtle);
	}
</style>
