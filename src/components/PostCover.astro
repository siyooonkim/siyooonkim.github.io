---
import type { CollectionEntry } from 'astro:content';

type PostData = CollectionEntry<'blog'>['data'];

interface Props {
	post?: CollectionEntry<'blog'>;
	data?: PostData;
	compact?: boolean;
}

const { post, data, compact = false } = Astro.props;
const source = post?.data ?? data;

if (!source) {
	throw new Error('PostCover requires either post or data.');
}

const titleWords = source.title.split(' ').slice(0, 5).join(' ');
const publishedYear = source.pubDate instanceof Date ? source.pubDate.getFullYear() : new Date(source.pubDate).getFullYear();
---

{
	source.heroImage ? (
		<img
			class="cover-image"
			src={source.heroImage}
			alt={source.title}
		/>
	) : (
		<div class:list={["generated-cover", { compact }]}>
			<div class="generated-cover__panel">
				<p class="generated-cover__category">{source.category}</p>
				<h4>{titleWords}</h4>
				<span>{publishedYear}</span>
			</div>
		</div>
	)
}

<style>
	.cover-image {
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 10;
		object-fit: cover;
	}
	.generated-cover {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background:
			linear-gradient(180deg, #171d25 0%, #131921 100%);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	.generated-cover.compact {
		aspect-ratio: 4 / 5;
	}
	.generated-cover__panel {
		position: absolute;
		left: 9%;
		right: 9%;
		top: 12%;
		bottom: 12%;
		padding: 1rem 0.95rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		background: #f4f5f7;
		color: #141a21;
		border-radius: 2px;
	}
	.generated-cover__category {
		margin: 0;
		font-size: 0.62rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #475569;
	}
	h4 {
		margin: 0;
		font-size: clamp(0.9rem, 0.84rem + 0.22vw, 1.05rem);
		line-height: 1.45;
		color: #0f172a;
		font-weight: 700;
		letter-spacing: -0.01em;
	}
	span {
		font-size: 0.72rem;
		color: #475569;
	}
</style>
