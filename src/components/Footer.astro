---
import { SITE_AUTHOR } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-shell">
		<p>© {today.getFullYear()} {SITE_AUTHOR}</p>
		<div class="footer-links">
			<a href="https://github.com/siyooonkim" target="_blank" rel="noreferrer">GitHub</a>
			<a href="mailto:ksyoon0718@gmail.com">Email</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 1.5rem 0 2.5rem;
	}
	.footer-shell {
		width: min(960px, calc(100% - 48px));
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.8rem;
		padding-top: 1.25rem;
		border-top: 1px solid rgba(255, 255, 255, 0.06);
	}
	.footer-shell p {
		margin: 0;
		font-size: 0.78rem;
		color: var(--text-subtle);
	}
	.footer-links {
		display: flex;
		gap: 1rem;
	}
	.footer-links a {
		text-decoration: none;
		font-size: 0.78rem;
		color: var(--text-subtle);
		transition: color 160ms ease;
	}
	.footer-links a:hover {
		color: var(--text-strong);
	}
	@media (max-width: 480px) {
		.footer-shell {
			width: min(960px, calc(100% - 32px));
			flex-direction: column;
			text-align: center;
		}
	}
</style>
