---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import SiteLayout from './SiteLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

type Props = CollectionEntry<'blog'>['data'];

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface RelatedPost {
	slug: string;
	data: CollectionEntry<'blog'>['data'];
}

const { title, description, pubDate, updatedDate, heroImage, category, tags, headings = [], relatedPosts = [] } = Astro.props as Props & {
	headings?: Heading[];
	relatedPosts?: RelatedPost[];
};
---

<SiteLayout title={title} description={description}>
	<main class="article-shell">
		<article class="article-card">
			<header class="article-header">
				<p class="eyebrow">{category}</p>
				<h1>{title}</h1>
				<p class="description">{description}</p>
				<div class="meta-row">
					<div>
						<FormattedDate date={pubDate} />
						{updatedDate && <span class="updated"> · Updated <FormattedDate date={updatedDate} /></span>}
					</div>
					{tags.length > 0 && (
						<ul class="tag-list">
							{tags.map((tag: string) => <li>{tag}</li>)}
						</ul>
					)}
				</div>
			</header>

			{heroImage && (
				<div class="hero-image">
					<Image width={1440} src={heroImage} alt={title} />
				</div>
			)}

			<div class="article-grid">
				<div class="prose"><slot /></div>
				<TableOfContents headings={headings} />
			</div>

			{relatedPosts.length > 0 && (
				<section class="related-posts">
					<p class="section-label">Related posts</p>
					<div class="related-grid">
						{relatedPosts.map((post: RelatedPost) => (
							<a href={`/posts/${post.slug}/`}>
								<strong>{post.data.title}</strong>
								<span>{post.data.description}</span>
							</a>
						))}
					</div>
				</section>
			)}
		</article>
	</main>
</SiteLayout>

<style>
	.article-shell {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 4rem 0 3rem;
	}
	.article-card {
		display: grid;
		gap: 2rem;
	}
	.article-header {
		max-width: 760px;
	}
	.eyebrow,
	.section-label {
		margin: 0 0 1rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-subtle);
	}
	h1 {
		margin: 0;
		font-size: clamp(2.9rem, 2.2rem + 2.1vw, 4.75rem);
		line-height: 1.05;
	}
	.description {
		margin: 1.25rem 0 0;
		font-size: clamp(1.08rem, 1rem + 0.4vw, 1.35rem);
		color: var(--text-muted);
	}
	.meta-row {
		margin-top: 1.5rem;
		display: flex;
		gap: 1rem;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		color: var(--text-subtle);
	}
	.updated {
		color: var(--text-subtle);
	}
	.tag-list {
		list-style: none;
		display: flex;
		gap: 0.5rem;
		padding: 0;
		margin: 0;
		flex-wrap: wrap;
	}
	.tag-list li {
		padding: 0.32rem 0.7rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.06);
		font-size: 0.84rem;
	}
	.hero-image img {
		width: 100%;
		border-radius: 28px;
		border: 1px solid rgba(255, 255, 255, 0.08);
	}
	.article-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 260px;
		gap: 2rem;
		align-items: start;
	}
	.prose {
		min-width: 0;
	}
	.related-posts {
		padding-top: 1rem;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}
	.related-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	.related-grid a {
		display: grid;
		gap: 0.5rem;
		padding: 1rem 1.1rem;
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		text-decoration: none;
		color: inherit;
	}
	.related-grid span {
		color: var(--text-muted);
		font-size: 0.96rem;
	}
	@media (max-width: 1040px) {
		.article-grid {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 720px) {
		.article-shell {
			padding-top: 2.2rem;
		}
		.related-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
