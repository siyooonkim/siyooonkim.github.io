---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_AUTHOR } from '../consts';
---

<SiteLayout title="About" description={`About ${SITE_AUTHOR}` }>
	<main class="about-shell">
		<section class="intro">
			<p class="eyebrow">About</p>
			<h1>{SITE_AUTHOR}</h1>
			<p>
				Software engineer and deep learning researcher interested in scalable product systems,
				maintainable architecture, and the friction between elegant abstractions and messy reality.
			</p>
		</section>

		<section class="grid">
			<div>
				<h2>What I write about</h2>
				<p>
					I use this blog for engineering notes that are concrete enough to reuse: backend design,
					frontend trade-offs, AI-assisted development workflows, and lessons that only show up after
					you have to maintain code for a while.
				</p>
			</div>
			<div>
				<h2>Current focus</h2>
				<ul>
					<li>Scalable commerce and O2O services</li>
					<li>Multimodal deep learning research</li>
					<li>Writing clear technical essays in Korean and English</li>
				</ul>
			</div>
		</section>
	</main>
</SiteLayout>

<style>
	.about-shell {
		width: min(880px, calc(100% - 32px));
		margin: 0 auto;
		padding: 4rem 0 3rem;
		display: grid;
		gap: 2rem;
	}
	.eyebrow {
		margin: 0 0 1rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-subtle);
	}
	h1 {
		margin: 0;
		font-size: clamp(2.8rem, 2.2rem + 1.9vw, 4.2rem);
	}
	.intro p:last-child {
		color: var(--text-muted);
		font-size: 1.14rem;
		max-width: 60ch;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	.grid > div {
		padding: 1.4rem;
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}
	.grid h2 {
		margin-top: 0;
		font-size: 1.4rem;
	}
	ul {
		margin: 0;
		padding-left: 1.2rem;
		color: var(--text-muted);
	}
	@media (max-width: 720px) {
		.about-shell {
			padding-top: 2.3rem;
		}
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
