---
import { getCollection } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';
import ShelfCard from '../components/ShelfCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getSeriesKey, getSeriesNum } from '../utils/series';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft));

const seriesLatest = new Map<string, number>();
for (const p of allPosts) {
	const key = getSeriesKey(p.data.title);
	const val = p.data.pubDate.valueOf();
	const prev = seriesLatest.get(key) || 0;
	if (val > prev) seriesLatest.set(key, val);
}

const posts = allPosts.sort((a, b) => {
	const keyA = getSeriesKey(a.data.title);
	const keyB = getSeriesKey(b.data.title);
	const latestA = seriesLatest.get(keyA) || 0;
	const latestB = seriesLatest.get(keyB) || 0;
	if (latestA !== latestB) return latestB - latestA;
	if (keyA !== keyB) return keyA.localeCompare(keyB);
	return getSeriesNum(a.data.title) - getSeriesNum(b.data.title);
});

const sectionOrder = ['Essay', '사이드 프로젝트', '개발일지', '데이터베이스', '딥러닝'];

const sectionDescriptions: Record<string, string> = {
	'Essay': '살아가며 느끼는 생각들',
	'사이드 프로젝트': '직접 만들고 출시한 서비스',
	'개발일지': '오늘 풀었던 문제와 설계 결정들',
	'데이터베이스': '데이터 모델링, 쿼리, 성능과 운영',
	'딥러닝': '모델링, 실험, 그리고 ML 엔지니어링',
};

const groupedSections = sectionOrder
	.map((category) => ({
		category,
		posts: posts.filter((post) => post.data.category === category),
	}))
	.filter((section) => section.posts.length > 0);
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main class="home-shell">
		<section class="hero">
			<div class="profile-row">
				<img src="/images/profile.jpg" alt="Siyoon" class="profile-photo" />
				<div class="profile-text">
					<h1>{SITE_TITLE}</h1>
					<p class="profile-role">Problem Solver</p>
				</div>
			</div>
			<p class="hero-intro">
				Chasing the <strong>core</strong>.  <br/>
				Building the <strong>solution</strong>.  <br/>
				Leaving a <strong>trace</strong>. <br/> 
			</p>
			<div class="contact-links">
				<a href="mailto:ksyoon0718@gmail.com" class="contact-link">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
					ksyoon0718@gmail.com
				</a>
				<a href="https://github.com/siyooonkim" target="_blank" rel="noreferrer" class="contact-link">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
					GitHub
				</a>
			</div>
		</section>

		<nav class="category-nav">
			{sectionOrder.map((cat) => (
				<a href={`#section-${cat}`} class="category-chip">{cat}</a>
			))}
		</nav>

		{groupedSections.map((section) => (
			<section class="shelf-section" id={`section-${section.category}`}>
				<div class="section-head">
					<div>
						<h2 class="section-label">{section.category}</h2>
						<p class="section-description">{sectionDescriptions[section.category]}</p>
					</div>
					<a href="/posts" class="view-all">전체 보기</a>
				</div>
				<div class="shelf-grid">
					{section.posts.slice(0, 4).map((post) => <ShelfCard post={post} />)}
				</div>
			</section>
		))}
	</main>
</SiteLayout>

<style>
	.home-shell {
		width: min(960px, calc(100% - 48px));
		margin: 0 auto;
		padding: 2rem 0 3rem;
		display: grid;
		gap: 2.5rem;
	}

	/* Hero */
	.hero {
		padding: 2.5rem 0 1.5rem;
		text-align: center;
	}
	.profile-row {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.2rem;
		margin-bottom: 1.2rem;
	}
	.profile-photo {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid rgba(255, 255, 255, 0.1);
	}
	.profile-text {
		text-align: left;
	}
	.profile-role {
		margin: 0.2rem 0 0;
		font-size: 0.85rem;
		color: var(--text-muted);
		font-weight: 500;
	}
	h1 {
		margin: 0;
		font-size: clamp(1.8rem, 1.5rem + 1vw, 2.4rem);
		letter-spacing: -0.02em;
	}
	.hero-intro {
		margin: 0 0 1.5rem;
		font-size: 0.95rem;
		color: var(--text-muted);
		line-height: 1.8;
	}
	.hero-intro strong {
		color: var(--accent);
		font-weight: 600;
	}

	/* Contact Links */
	.contact-links {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}
	.contact-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.5rem 0.9rem;
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.82rem;
		transition: all 160ms ease;
	}
	.contact-link:hover {
		background: rgba(255, 255, 255, 0.08);
		color: var(--text-strong);
		border-color: rgba(255, 255, 255, 0.14);
	}
	.contact-link svg {
		flex-shrink: 0;
	}

	/* Category Nav */
	.category-nav {
		display: flex;
		gap: 0.5rem;
		justify-content: center;
		flex-wrap: wrap;
		padding: 0.5rem 0;
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
	}
	.category-chip {
		padding: 0.45rem 0.85rem;
		border-radius: 6px;
		background: transparent;
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.82rem;
		font-weight: 500;
		transition: all 160ms ease;
	}
	.category-chip:hover {
		background: rgba(255, 255, 255, 0.06);
		color: var(--text-strong);
	}

	/* Sections */
	.shelf-section {
		display: grid;
		gap: 1rem;
	}
	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: end;
		gap: 1rem;
	}
	.section-label {
		margin: 0 0 0.25rem;
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--text-strong);
	}
	.section-description {
		margin: 0;
		font-size: 0.82rem;
		color: var(--text-subtle);
	}
	.view-all {
		text-decoration: none;
		color: var(--text-subtle);
		font-size: 0.78rem;
		white-space: nowrap;
		transition: color 160ms ease;
	}
	.view-all:hover {
		color: var(--accent);
	}

	/* Grid */
	.shelf-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}

	@media (max-width: 820px) {
		.home-shell {
			width: min(960px, calc(100% - 32px));
			gap: 2rem;
		}
		.hero-sub br {
			display: none;
		}
		.shelf-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
		.section-head {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.5rem;
		}
	}

	@media (max-width: 480px) {
		.hero-intro br {
			display: none;
		}
		.contact-links {
			flex-direction: column;
			align-items: center;
		}
	}
</style>
