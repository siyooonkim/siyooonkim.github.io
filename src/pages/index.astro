---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featuredPost, ...latestPosts] = posts;

const sectionOrder = ['개발일지', 'AI', '백엔드·데이터베이스', '개발 노트', '에세이'];

const groupedSections = sectionOrder
	.map((category) => ({
		category,
		posts: posts.filter((post) => post.data.category === category),
	}))
	.filter((section) => section.posts.length > 0);

const rankedPosts = latestPosts.slice(0, 6);
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main class="home-shell">
		<section class="hero">
			<div class="hero-grid"></div>
			<p class="eyebrow">Software engineering · research · long-form notes</p>
			<h1>{SITE_TITLE}</h1>
			<p class="hero-tagline">직접 글을 쓰는 지루함을 즐기기 위한 아카이브</p>
			<div class="hero-actions">
				<a class="primary" href="/posts">Read posts</a>
				<a class="secondary" href="/about">About me</a>
			</div>
		</section>

		{featuredPost && (
			<section class="featured">
				<div class="section-head">
					<p class="section-label">Featured</p>
				</div>
				<PostCard post={featuredPost} featured />
			</section>
		)}

		<section class="ranked">
			<div class="section-head">
				<p class="section-label">Steady notes</p>
				<a href="/posts">View all</a>
			</div>
			<ol class="ranked-grid">
				{rankedPosts.map((post, index) => (
					<li>
						<span class="rank-index">{index + 1}</span>
						<div class="rank-copy">
							<a href={`/posts/${post.slug}/`}>{post.data.title}</a>
							<p>{post.data.category} / {post.data.tags.slice(0, 2).join(' / ')}</p>
						</div>
					</li>
				))}
			</ol>
		</section>

		{groupedSections.map((section) => (
			<section class="shelf-section">
				<div class="section-head">
					<p class="section-label">{section.category}</p>
					<a href="/posts">View all</a>
				</div>
				<div class="shelf-grid">
					{section.posts.slice(0, 3).map((post) => <PostCard post={post} />)}
				</div>
			</section>
		))}
	</main>
</SiteLayout>

<style>
	.home-shell {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 3.25rem 0 2.5rem;
		display: grid;
		gap: 2.4rem;
	}
	.hero {
		position: relative;
		padding: 3rem 0 1.4rem;
		min-height: 16rem;
		display: grid;
		place-items: center;
		text-align: center;
		isolation: isolate;
	}
	.hero-grid {
		position: absolute;
		inset: 0;
		border-radius: 24px;
		background:
			linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
		background-size: 42px 42px;
		mask-image: radial-gradient(circle at center, black 35%, transparent 90%);
		opacity: 0.38;
		pointer-events: none;
		z-index: -1;
	}
	.eyebrow,
	.section-label {
		margin: 0 0 1rem;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-subtle);
	}
	h1 {
		margin: 0;
		font-size: clamp(2.2rem, 1.8rem + 1.4vw, 3.2rem);
		line-height: 0.98;
		max-width: none;
		letter-spacing: -0.02em;
	}
	.hero-tagline {
		margin: 0.8rem 0 0;
		font-size: 0.9rem;
		color: var(--text-body);
	}
	.hero-copy {
		margin: 1.4rem 0 0;
		font-size: clamp(1.08rem, 1rem + 0.45vw, 1.34rem);
		color: var(--text-muted);
		max-width: 54ch;
	}
	.hero-topics {
		margin: 1.1rem 0 0;
		font-size: 0.95rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-subtle);
	}
	.hero-actions {
		display: flex;
		gap: 0.9rem;
		flex-wrap: wrap;
		margin-top: 1.25rem;
	}
	.hero-actions a {
		padding: 0.64rem 0.92rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.84rem;
	}
	.hero-actions .primary {
		background: var(--accent);
		color: #081019;
	}
	.hero-actions .secondary {
		background: rgba(255, 255, 255, 0.04);
		color: var(--text-strong);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}
	.section-head {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: center;
		margin-bottom: 0.75rem;
	}
	.section-head p {
		margin: 0;
	}
	.section-head a {
		text-decoration: none;
		color: var(--text-muted);
		font-size: 0.88rem;
	}
	.ranked-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem 1.6rem;
	}
	.ranked-grid li {
		display: grid;
		grid-template-columns: 42px 1fr;
		gap: 0.85rem;
		align-items: start;
	}
	.rank-index {
		font-size: 1.35rem;
		line-height: 1;
		color: rgba(255, 255, 255, 0.3);
	}
	.rank-copy a {
		color: var(--text-strong);
		text-decoration: none;
		font-size: 1.02rem;
		line-height: 1.3;
	}
	.rank-copy p {
		margin: 0.35rem 0 0;
		color: var(--text-subtle);
		font-size: 0.82rem;
	}
	.shelf-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.85rem;
	}
	@media (max-width: 820px) {
		.home-shell {
			padding-top: 2.3rem;
		}
		.ranked-grid,
		.shelf-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
