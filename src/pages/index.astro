---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featuredPost, ...latestPosts] = posts;
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main class="home-shell">
		<section class="hero">
			<p class="eyebrow">Software engineering · Deep learning · Product thinking</p>
			<h1>Thoughtful notes from building systems that need to survive change.</h1>
			<p class="hero-copy">
				I am {SITE_AUTHOR}, a software engineer and researcher writing about backend architecture,
				frontend trade-offs, AI-era development workflows, and practical lessons from real projects.
			</p>
			<div class="hero-actions">
				<a class="primary" href="/posts">Read posts</a>
				<a class="secondary" href="/about">About me</a>
			</div>
		</section>

		{featuredPost && (
			<section class="featured">
				<div class="section-head">
					<p class="section-label">Featured post</p>
				</div>
				<PostCard post={featuredPost} featured />
			</section>
		)}

		<section class="latest">
			<div class="section-head">
				<p class="section-label">Latest writing</p>
				<a href="/posts">View all</a>
			</div>
			<div class="latest-grid">
				{latestPosts.slice(0, 4).map((post) => <PostCard post={post} />)}
			</div>
		</section>
	</main>
</SiteLayout>

<style>
	.home-shell {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 4rem 0 3rem;
		display: grid;
		gap: 3rem;
	}
	.hero {
		max-width: 820px;
		padding: 2rem 0 1rem;
	}
	.eyebrow,
	.section-label {
		margin: 0 0 1rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-subtle);
	}
	h1 {
		margin: 0;
		font-size: clamp(3rem, 2.35rem + 2.3vw, 5.3rem);
		line-height: 0.98;
		max-width: 13ch;
	}
	.hero-copy {
		margin: 1.4rem 0 0;
		font-size: clamp(1.08rem, 1rem + 0.45vw, 1.34rem);
		color: var(--text-muted);
		max-width: 60ch;
	}
	.hero-actions {
		display: flex;
		gap: 0.9rem;
		flex-wrap: wrap;
		margin-top: 1.8rem;
	}
	.hero-actions a {
		padding: 0.88rem 1.2rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
	}
	.hero-actions .primary {
		background: var(--accent);
		color: #081019;
	}
	.hero-actions .secondary {
		background: rgba(255, 255, 255, 0.04);
		color: var(--text-strong);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}
	.section-head {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: center;
		margin-bottom: 1rem;
	}
	.section-head p {
		margin: 0;
	}
	.section-head a {
		text-decoration: none;
		color: var(--text-muted);
	}
	.latest-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.1rem;
	}
	@media (max-width: 820px) {
		.home-shell {
			padding-top: 2.3rem;
		}
		.latest-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
