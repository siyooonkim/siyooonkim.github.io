---
import { getCollection } from 'astro:content';
import ShelfCard from '../components/ShelfCard.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const sectionOrder = ['이런저런', '딥러닝', '개발 일지', 'Database', '사이드 프로젝트'];

const sectionDescriptions: Record<string, string> = {
	'이런저런': '생각, 관점, 그리고 개발 바깥의 메모',
	'딥러닝': '모델링, 실험, 운영 사이에서 남기는 기록',
	'개발 일지': '오늘 풀었던 문제와 설계 결정들',
	Database: '데이터 모델링, 쿼리, 성능과 운영',
	'사이드 프로젝트': '버스벨과 같은 직접 만드는 제품 기록',
};

const groupedSections = sectionOrder
	.map((category) => ({
		category,
		posts: posts.filter((post) => post.data.category === category),
	}))
	.filter((section) => section.posts.length > 0);
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main class="home-shell">
		<section class="hero">
			<p class="eyebrow">Siyoon's library</p>
			<h1>{SITE_TITLE}</h1>
			<p class="hero-tagline">직접 글을 쓰는 지루함을 즐기기 위한 공간</p>
			<p class="hero-note">카테고리별로 모아두고, 커버부터 훑어볼 수 있게 정리한 기록장.</p>
		</section>

		{groupedSections.map((section) => (
			<section class="shelf-section">
				<div class="section-head">
					<div>
						<p class="section-label">{section.category}</p>
						<p class="section-description">{sectionDescriptions[section.category]}</p>
					</div>
					<a href="/posts">View all</a>
				</div>
				<div class="shelf-grid">
					{section.posts.slice(0, 5).map((post) => <ShelfCard post={post} />)}
				</div>
			</section>
		))}
	</main>
</SiteLayout>

<style>
	.home-shell {
		width: min(1040px, calc(100% - 56px));
		margin: 0 auto;
		padding: 2.4rem 0 2rem;
		display: grid;
		gap: 2.4rem;
	}
	.hero {
		padding: 2rem 0 0.8rem;
		min-height: auto;
		display: grid;
		place-items: center;
		text-align: center;
	}
	.eyebrow,
	.section-label {
		margin: 0 0 0.5rem;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-subtle);
	}
	h1 {
		margin: 0;
		font-size: clamp(2.1rem, 1.8rem + 0.8vw, 2.8rem);
		line-height: 0.98;
		max-width: none;
		letter-spacing: -0.02em;
	}
	.hero-tagline {
		margin: 0.7rem 0 0;
		font-size: 0.92rem;
		color: var(--text-body);
	}
	.hero-note {
		margin: 0.75rem 0 0;
		font-size: 0.82rem;
		color: var(--text-muted);
		max-width: 48ch;
	}
	.section-head {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: end;
		margin-bottom: 0.85rem;
	}
	.section-head p {
		margin: 0;
	}
	.section-description {
		font-size: 0.82rem;
		color: var(--text-subtle);
	}
	.section-head a {
		text-decoration: none;
		color: var(--text-muted);
		font-size: 0.82rem;
	}
	.shelf-grid {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
	}
	.shelf-section {
		display: grid;
		gap: 0.4rem;
	}
	@media (max-width: 820px) {
		.home-shell {
			width: min(1040px, calc(100% - 32px));
			padding-top: 2rem;
		}
		.shelf-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
		.section-head {
			align-items: start;
			flex-direction: column;
		}
	}
</style>
