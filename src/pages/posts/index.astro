---
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Group by category
const categories = ['AI 관련', '딥러닝', '개발일지', '데이터베이스', '그냥저냥'];
const groupedPosts = categories
	.map((cat) => ({
		category: cat,
		posts: posts.filter((p) => p.data.category === cat),
	}))
	.filter((g) => g.posts.length > 0);
---

<SiteLayout title="Posts" description="All posts">
	<main class="posts-shell">
		<section class="intro">
			<h1>모든 글</h1>
			<p>기록해둔 글들을 카테고리별로 모아봤습니다.</p>
		</section>

		<nav class="filter-nav">
			<button class="filter-chip active" data-category="all">전체 ({posts.length})</button>
			{groupedPosts.map((g) => (
				<button class="filter-chip" data-category={g.category}>{g.category} ({g.posts.length})</button>
			))}
		</nav>

		<div class="posts-grid">
			{posts.map((post, index) => (
				<div class="post-item" data-category={post.data.category}>
					<PostCard post={post} featured={false} />
				</div>
			))}
		</div>
	</main>
</SiteLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', function() {
		const chips = document.querySelectorAll('.filter-chip');
		const items = document.querySelectorAll('.post-item');

		chips.forEach(function(chip) {
			chip.addEventListener('click', function() {
				chips.forEach(function(c) { c.classList.remove('active'); });
				chip.classList.add('active');

				const category = chip.getAttribute('data-category');

				items.forEach(function(item) {
					if (category === 'all' || item.getAttribute('data-category') === category) {
						item.style.display = '';
					} else {
						item.style.display = 'none';
					}
				});
			});
		});
	});
</script>

<style>
	.posts-shell {
		width: min(960px, calc(100% - 48px));
		margin: 0 auto;
		padding: 2rem 0 3rem;
	}

	.intro {
		margin-bottom: 1.5rem;
	}
	h1 {
		margin: 0 0 0.5rem;
		font-size: clamp(1.6rem, 1.4rem + 0.6vw, 2rem);
	}
	.intro p {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.88rem;
	}

	/* Filter Nav */
	.filter-nav {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
		margin-bottom: 1.5rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--line);
	}
	.filter-chip {
		padding: 0.4rem 0.75rem;
		border-radius: 6px;
		background: transparent;
		border: none;
		color: var(--text-muted);
		font-size: 0.78rem;
		cursor: pointer;
		transition: all 160ms ease;
	}
	.filter-chip:hover,
	.filter-chip.active {
		background: rgba(255, 255, 255, 0.06);
		color: var(--text-strong);
	}

	.post-item {
		display: block;
	}
	.post-item[style*="display: none"] {
		display: none !important;
	}

	/* Grid */
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	.posts-grid :global(.featured) {
		grid-column: 1 / -1;
	}

	@media (max-width: 720px) {
		.posts-shell {
			width: min(960px, calc(100% - 32px));
		}
		.posts-grid {
			grid-template-columns: 1fr;
		}
		.posts-grid :global(.featured) {
			grid-column: 1;
		}
	}
</style>
