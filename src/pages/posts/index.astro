---
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<SiteLayout title="Posts" description="All posts">
	<main class="posts-shell">
		<section class="intro">
			<p class="eyebrow">Posts</p>
			<h1>Writing archive</h1>
			<p>Long-form engineering essays, implementation notes, and decisions worth remembering.</p>
		</section>
		<div class="posts-grid">
			{posts.map((post, index) => <PostCard post={post} featured={index === 0} />)}
		</div>
	</main>
</SiteLayout>

<style>
	.posts-shell {
		width: min(1080px, calc(100% - 96px));
		margin: 0 auto;
		padding: 2.8rem 0 2.2rem;
	}
	.eyebrow {
		margin: 0 0 1rem;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-subtle);
	}
	.intro {
		max-width: 680px;
		margin-bottom: 1.4rem;
	}
	h1 {
		margin: 0;
		font-size: clamp(2rem, 1.72rem + 1vw, 2.8rem);
	}
	.intro p:last-child {
		color: var(--text-muted);
		font-size: 0.92rem;
	}
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.72rem;
	}
	.posts-grid :global(.featured) {
		grid-column: 1 / -1;
	}
	@media (max-width: 820px) {
		.posts-shell {
			width: min(1080px, calc(100% - 40px));
			padding-top: 2.3rem;
		}
		.posts-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
