---
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => {
		const dateDiff = b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
		if (dateDiff !== 0) return dateDiff;
		return a.data.title.localeCompare(b.data.title);
	},
);

const categories = ['AI 관련', '딥러닝', '개발일지', '데이터베이스', '그냥저냥'];
const groupedPosts = categories
	.map((cat) => ({
		category: cat,
		posts: posts.filter((p) => p.data.category === cat),
	}))
	.filter((g) => g.posts.length > 0);

const PER_PAGE = 8;
---

<SiteLayout title="Posts" description="All posts">
	<main class="posts-shell">
		<section class="intro">
			<h1>모든 글</h1>
			<p>기록해둔 글들을 카테고리별로 모아봤습니다.</p>
		</section>

		<nav class="filter-nav">
			<button class="filter-chip active" data-category="all">전체 ({posts.length})</button>
			{groupedPosts.map((g) => (
				<button class="filter-chip" data-category={g.category}>{g.category} ({g.posts.length})</button>
			))}
		</nav>

		<div class="posts-grid">
			{posts.map((post, index) => (
				<div class="post-item" data-category={post.data.category} data-index={index}>
					<PostCard post={post} featured={false} />
				</div>
			))}
		</div>

		<nav class="pagination">
			<button class="page-btn prev" disabled>&larr;</button>
			<span class="page-info"></span>
			<button class="page-btn next">&rarr;</button>
		</nav>
	</main>
</SiteLayout>

<script is:inline define:vars={{ PER_PAGE }}>
	document.addEventListener('DOMContentLoaded', function() {
		const chips = document.querySelectorAll('.filter-chip');
		const items = Array.from(document.querySelectorAll('.post-item'));
		const prevBtn = document.querySelector('.page-btn.prev');
		const nextBtn = document.querySelector('.page-btn.next');
		const pageInfo = document.querySelector('.page-info');
		const pagination = document.querySelector('.pagination');

		let currentPage = 1;
		let currentCategory = 'all';

		function getVisibleItems() {
			return items.filter(function(item) {
				return currentCategory === 'all' || item.getAttribute('data-category') === currentCategory;
			});
		}

		function render() {
			var visible = getVisibleItems();
			var totalPages = Math.ceil(visible.length / PER_PAGE);
			if (currentPage > totalPages) currentPage = totalPages;
			if (currentPage < 1) currentPage = 1;

			var start = (currentPage - 1) * PER_PAGE;
			var end = start + PER_PAGE;

			items.forEach(function(item) { item.style.display = 'none'; });
			visible.forEach(function(item, i) {
				if (i >= start && i < end) {
					item.style.display = '';
				}
			});

			pageInfo.textContent = currentPage + ' / ' + totalPages;
			prevBtn.disabled = currentPage <= 1;
			nextBtn.disabled = currentPage >= totalPages;

			if (totalPages <= 1) {
				pagination.style.display = 'none';
			} else {
				pagination.style.display = '';
			}
		}

		chips.forEach(function(chip) {
			chip.addEventListener('click', function() {
				chips.forEach(function(c) { c.classList.remove('active'); });
				chip.classList.add('active');
				currentCategory = chip.getAttribute('data-category');
				currentPage = 1;
				render();
			});
		});

		prevBtn.addEventListener('click', function() {
			if (currentPage > 1) { currentPage--; render(); }
		});

		nextBtn.addEventListener('click', function() {
			var totalPages = Math.ceil(getVisibleItems().length / PER_PAGE);
			if (currentPage < totalPages) { currentPage++; render(); }
		});

		render();
	});
</script>

<style>
	.posts-shell {
		width: min(960px, calc(100% - 48px));
		margin: 0 auto;
		padding: 2rem 0 3rem;
	}

	.intro {
		margin-bottom: 1.5rem;
	}
	h1 {
		margin: 0 0 0.5rem;
		font-size: clamp(1.6rem, 1.4rem + 0.6vw, 2rem);
	}
	.intro p {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.88rem;
	}

	.filter-nav {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
		margin-bottom: 1.5rem;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--line);
	}
	.filter-chip {
		padding: 0.4rem 0.75rem;
		border-radius: 6px;
		background: transparent;
		border: none;
		color: var(--text-muted);
		font-size: 0.78rem;
		cursor: pointer;
		transition: all 160ms ease;
	}
	.filter-chip:hover,
	.filter-chip.active {
		background: rgba(255, 255, 255, 0.06);
		color: var(--text-strong);
	}

	.post-item {
		display: block;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.pagination {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		margin-top: 2rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--line);
	}
	.page-btn {
		padding: 0.4rem 0.8rem;
		border-radius: 6px;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.1);
		color: var(--text-muted);
		font-size: 0.85rem;
		cursor: pointer;
		transition: all 160ms ease;
	}
	.page-btn:hover:not(:disabled) {
		background: rgba(255, 255, 255, 0.08);
		color: var(--text-strong);
	}
	.page-btn:disabled {
		opacity: 0.3;
		cursor: default;
	}
	.page-info {
		font-size: 0.82rem;
		color: var(--text-muted);
	}

	@media (max-width: 720px) {
		.posts-shell {
			width: min(960px, calc(100% - 32px));
		}
		.posts-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
